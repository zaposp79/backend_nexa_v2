# Variables de entorno de ejemplo para NEXA Simulator
# Copia este archivo a .env y completa valores; no commitees secretos reales.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=NEXA Simulator API
APP_DESCRIPTION=Motor de pricing + API de parametrización y simulación
APP_VERSION=1.0.0
API_PREFIX=api
API_VERSION=v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
HEALTH_PATH=/health
SERVICE_NAME=nexa-simulator-api
APP_RELOAD=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
PYTHONUNBUFFERED=1
VERBOSE_LOGGING=False

# Opt-in para usar Cosmos en desarrollo local con documentación y reload.
# Por seguridad, DB_PROVIDER=cosmos o COSMOS_ENDPOINT obligan APP_ENV=production
# (donde la documentación se desactiva). Pon ALLOW_COSMOS_NON_PRODUCTION=true para permitir,
# a propósito, Cosmos con APP_ENV=development. NO tiene efecto en production.
#   Local con docs    : APP_ENV=development + DB_PROVIDER=cosmos + ALLOW_COSMOS_NON_PRODUCTION=true
#   App Service (prod): APP_ENV=production  + DB_PROVIDER=cosmos  (deja esta vacía/false; docs OFF)
ALLOW_COSMOS_NON_PRODUCTION=false

# Opcional: claves de APIs de terceros (placeholders de ejemplo)
#SOME_API_KEY=
#ANOTHER_SECRET=

# --- Capa de persistencia (FASE DB) -----------------------------------------
# Backend documental activo. json (default) | cosmos
DB_PROVIDER=json
# Directorio raíz del backend JSON; rutas relativas resuelven desde la raíz del repo.
JSON_STORAGE_PATH=storage
# Configuración Cosmos DB; requerida SOLO con DB_PROVIDER=cosmos. Dejar vacía con json.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
COSMOS_CONTAINER=

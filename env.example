# Variables de entorno de ejemplo para NEXA Simulator
# Copia este archivo a .env y completa valores; no commitees secretos reales.
#
# ─── CONTROL DE SWAGGER / DOCUMENTACIÓN ─────────────────────────────────────
#
#  APP_ENV=development  →  Swagger EN  (/docs y /redoc accesibles)
#  APP_ENV=production   →  Swagger OFF (rutas /docs, /redoc y /openapi.json
#                           inexistentes; ni siquiera devuelven 404)
#
#  Regla simple: cambiar APP_ENV=production en .env (o en Azure Application
#  Settings) es todo lo que se necesita para apagar la documentación.
#
#  En Azure App Service las variables de Application Settings tienen prioridad
#  sobre el .env (el .env usa setdefault — nunca sobreescribe el entorno real).
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── MODO ACTIVO: elegir UNO de los dos bloques ──────────────────────────────
#
# BLOQUE A — DESARROLLO LOCAL (Swagger ON, hot reload ON)
APP_ENV=development
APP_RELOAD=true
#
# BLOQUE B — PRODUCCIÓN / PREPRODUCCIÓN (Swagger OFF, hot reload OFF)
# Descomentar las 2 líneas de abajo y comentar las 2 de arriba para probar
# el modo producción localmente antes de desplegar a Azure.
# APP_ENV=production
# APP_RELOAD=false
#
# Nota: en Azure App Service NO uses el .env; configura APP_ENV y APP_RELOAD
# directamente en Configuration > Application Settings del portal.
# ─────────────────────────────────────────────────────────────────────────────

APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=NEXA Simulator API
APP_DESCRIPTION=Motor de pricing + API de parametrización y simulación
APP_VERSION=1.0.0
API_PREFIX=api
API_VERSION=v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
HEALTH_PATH=/health
SERVICE_NAME=nexa-simulator-api
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
PYTHONUNBUFFERED=1
VERBOSE_LOGGING=False

# ─── COSMOS DB (solo si DB_PROVIDER=cosmos) ──────────────────────────────────
#
# Por seguridad, si DB_PROVIDER=cosmos o COSMOS_ENDPOINT está definido la app
# exige APP_ENV=production para arrancar (los docs quedan desactivados).
# Para usar Cosmos en desarrollo local con docs activos, pon:
#   ALLOW_COSMOS_NON_PRODUCTION=true
#
#   Local + Cosmos + docs : APP_ENV=development + ALLOW_COSMOS_NON_PRODUCTION=true
#   Azure App Service prod: APP_ENV=production  (ALLOW_COSMOS_NON_PRODUCTION ignorado)
#
ALLOW_COSMOS_NON_PRODUCTION=false

# Opcional: claves de APIs de terceros (placeholders de ejemplo)
#SOME_API_KEY=
#ANOTHER_SECRET=

# --- Capa de persistencia (FASE DB) -----------------------------------------
# Backend documental activo. json (default) | cosmos
DB_PROVIDER=json
# Directorio raíz del backend JSON; rutas relativas resuelven desde la raíz del repo.
JSON_STORAGE_PATH=storage
# Configuración Cosmos DB; requerida SOLO con DB_PROVIDER=cosmos. Dejar vacía con json.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=
# Container de parametrización (HR/GN/OP) — obligatorio con DB_PROVIDER=cosmos
COSMOS_CONTAINER_PARAMETRIZATION=parametrization
# Container de configuración (simulation drafts) — obligatorio con DB_PROVIDER=cosmos
COSMOS_CONTAINER_SIMULATION=configuration

# ─── AZURE APP SERVICE — Application Settings obligatorias ──────────────────
#
#  IMPORTANTE: En Azure NO uses el archivo .env. Configura estas variables en:
#  Azure Portal → App Service → Configuration → Application Settings
#
#  Mínimo requerido para arrancar en producción:
#
#    APP_ENV=production
#    APP_RELOAD=false
#    CORS_ALLOWED_ORIGINS=https://tu-frontend.azurewebsites.net
#    JSON_STORAGE_PATH=/home/site/wwwroot/storage
#    DB_PROVIDER=json
#
#  Notas:
#  - CORS_ALLOWED_ORIGINS es OBLIGATORIO en production (falla al arrancar si falta).
#    Separar múltiples orígenes con coma: https://a.com,https://b.com
#    El wildcard * NO está permitido en production.
#  - JSON_STORAGE_PATH debe apuntar a /home/site/wwwroot/storage (directorio
#    persistente en Azure App Service; se crea automáticamente al primer arranque).
#  - El puerto lo gestiona Azure vía WEBSITES_PORT (leído automáticamente por startup.sh).
#    No es necesario configurar APP_PORT en Azure.
#  - Startup Command en Azure:  bash /home/site/wwwroot/startup.sh
#  - Runtime:  python-3.12  (definido en runtime.txt — leído por Oryx en el build)
#
#  Opcional (si usas Cosmos DB en lugar de JSON):
#    DB_PROVIDER=cosmos
#    COSMOS_ENDPOINT=https://tu-cuenta.documents.azure.com:443/
#    COSMOS_KEY=<clave-de-acceso>
#    COSMOS_DATABASE=nexa
#    COSMOS_CONTAINER_PARAMETRIZATION=parametrization
#    COSMOS_CONTAINER_SIMULATION=configuration
# ─────────────────────────────────────────────────────────────────────────────

  "validation_rules": {
    "description": "Validaciones que deben aplicarse en Fase 8",
    "rules": [
      {
        "rule_id": "V8.1",
        "description": "Fail-fast si no hay canales en vision_tarifas",
        "where": "_configuracion_comercial() entrada",
        "condition": "resultado.vision_tarifas is None or len(canales) == 0",
        "action": "raise ValueError with clear message"
      },
      {
        "rule_id": "V8.2",
        "description": "Validar canal_principal != None",
        "where": "_configuracion_comercial() después selección",
        "condition": "canal_principal is None",
        "action": "raise ValueError('Selected principal channel is None')"
      },
      {
        "rule_id": "V8.3",
        "description": "No permitir silent defaults",
        "where": "Toda la serialización",
        "condition": "required_field is None",
        "action": "Retornar None explícito (no string vacío, no 0.0, no 1.0)"
      }
    ]

    "critical_fixes_phase_8": {
      "description": "Correcciones CRÍTICAS que deben hacerse en Fase 8",
      "fixes": [
        {
          "fix_id": "F8.1",
          "issue": "canales[0] hardcoding in _configuracion_comercial()",
          "file": "adapters/pricing_serializer.py",
          "lines": "214-227",
          "current_code": "canal_principal = canales[0] if canales else None",
          "options": [
            {
              "option": "A",
              "description": "Usar canal con máximo ingreso/facturación",
              "code": "canal_principal = max(canales, key=lambda c: c.facturacion) if canales else None"
            },
            {
              "option": "B",
              "description": "Usar promedio ponderado",
              "code": "canal_principal = _aggregate_channels_weighted(canales)"
            },
            {
              "option": "C",
              "description": "Requerir selección explícita",
              "code": "canal_principal = self._get_principal_channel(panel, canales)"
            }
          ],
          "recommendation": "OPTION A es más simple. Implementar con test multi-channel.",
          "affected_fields": [
            "modelo_cobro_principal",
            "pct_fijo_global",
            "pct_variable_global",
            "tarifa_fija",
            "tarifa_variable"
          ],
          "priority": "CRITICAL"
        },
        {
          "fix_id": "F8.2",
          "issue": "Silent defaults en _configuracion_comercial() si no hay canales",
          "file": "adapters/pricing_serializer.py",
          "lines": "229-233",
          "current_code": "modelo_cobro_principal = canal_principal.modelo_cobro if canal_principal else \"\"",
          "options": [
            {
              "option": "A",
              "description": "Fail loudly — raise error si no hay canales",
              "code": "if not canal_principal: raise ValueError('No active channels in vision_tarifas')"
            },
            {
              "option": "B",
              "description": "Return None/sentinel values",
              "code": "modelo_cobro_principal = canal_principal.modelo_cobro if canal_principal else None"
            },
            {
              "option": "C",
              "description": "Log warning pero continuar con defaults",
              "code": "if not canal_principal: logger.warning(f'No channels for {panel.cliente}'); # entonces defaults"
            }
          ],
          "recommendation": "OPTION A — fail loudly es más seguro. Frontend debe estar preparado.",
          "priority": "CRITICAL"
        },
        {
          "fix_id": "F8.3",

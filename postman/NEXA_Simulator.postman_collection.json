	"item": [
		{
			"name": "Simulation - Calculate",
			"item": [
				{
					"name": "POST /api/v1/simulation/calculate",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_input\": {\n    \"cliente\": \"Bancamia\",\n    \"linea_negocio\": \"SAC\",\n    \"ciudad\": \"Bogota\",\n    \"sede\": \"Principal\",\n    \"tipo_cliente\": \"Financiera\",\n    \"antiguedad_cliente_meses\": 24,\n    \"fecha_inicio\": \"2026-01-01\",\n    \"meses_contrato\": 24,\n    \"margen\": 0.18,\n    \"periodo_pago_dias\": 30,\n    \"ajuste_precio_tipo\": \"Indexado\",\n    \"ajuste_precio_frecuencia\": \"Anual\",\n    \"perfiles_cadena_a\": [\n      {\n        \"nombre\": \"Agente Voz\",\n        \"modalidad\": \"Inbound\",\n        \"canal\": \"Voz\",\n        \"fte\": 5.0,\n        \"salario_base\": 1200000,\n        \"es_soporte\": false\n      }\n    ],\n    \"canales_b\": [],\n    \"canales_c\": []\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/simulation/calculate",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"simulation",
								"calculate"
							],
							"query": [
								{
									"key": "mode",
									"value": "normal",
									"description": "Execution mode: 'normal' or 'certified'",
									"disabled": true
								}
							]
						},
						"description": "Execute the NEXA pricing engine. Returns simulation_id and calculates all 10 layers of the pricing model (nomina, no-payroll, cadena-b/c, costos-financieros, pyg, kpis, vision-tarifas, cost-to-serve, vision-pyg, vision-imprimible)."
					},
					"response": []
				}
			]
		},
